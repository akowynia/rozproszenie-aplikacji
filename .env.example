CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=url_shortener
BASE_URL=http://localhost:8000
DEFAULT_TTL_SECONDS=86400
MAX_TTL_SECONDS=2592000
SHORT_CODE_LENGTH=6
CLEANUP_INTERVAL_SECONDS=300
CLEANUP_STRATEGY=created_at
CLEANUP_TTL_SECONDS=31536000
CLEANUP_ENABLED=true

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=forbidden-urls-alerts
FORBIDDEN_WORDS=spam,phishing,malware,xxx,porn,gamble,scam,kurw,chuj,pierdol,jeb,cip,pizd
BLOCK_FORBIDDEN_URLS=false
